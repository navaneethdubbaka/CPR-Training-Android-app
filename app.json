{
  "expo": {
    "name": "CPR Trainer",
    "slug": "cpr-trainer",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "cprtrainer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cprtrainer",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to verify hand placement during CPR training",
        "NSMicrophoneUsageDescription": "Microphone is used for voice recognition during CPR training steps",
        "NSSpeechRecognitionUsageDescription": "Speech recognition is used to verify verbal CPR actions during training",
        "NSBluetoothAlwaysUsageDescription": "Bluetooth is used to connect to Arduino via Bluetooth serial modules",
        "NSBluetoothPeripheralUsageDescription": "Bluetooth is used to connect to Arduino via Bluetooth serial modules",
        "NSLocationWhenInUseUsageDescription": "Location access is required for Bluetooth device scanning"
      }
    },
    "android": {
      "package": "com.cprtrainer",
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.hardware.usb.host",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "android.hardware.usb.action.USB_DEVICE_ATTACHED",
          "category": ["android.intent.category.DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to verify hand placement during CPR training"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Microphone is used for voice recognition during CPR training"
        }
      ],
      "expo-dev-client",
      "./plugins/withJetifier",
      "./plugins/withUsbDeviceFilter",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Camera is used to track arm position during CPR training",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
